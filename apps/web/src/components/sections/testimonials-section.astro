---
import ReservationButton from "@/components/reservation-button.astro"
import ResponsiveImage from "@/components/responsive-image.astro"
import SectionEyebrow from "@/components/section-eyebrow.astro"
import { testimonials } from "@/lib/infinity-content"
import {
  Card,
  CardDescription,
  CardFooter,
  CardHeader,
} from "@workspace/ui/components/card"
---

<section
  class="mx-auto w-full max-w-[1440px] border-b px-5 py-16 sm:px-8 lg:px-10 lg:py-24"
>
  <div class="flex flex-col gap-8">
    <div class="flex flex-col justify-between gap-5 lg:flex-row lg:items-end">
      <div class="flex flex-col gap-3">
        <SectionEyebrow>INFINITY BARBER / Povedali ste o nás</SectionEyebrow>
        <h2
          class="text-4xl leading-tight font-medium text-balance break-words sm:text-7xl sm:leading-none"
        >
          Recenzie - Feedback -
        </h2>
      </div>
      <ReservationButton label="Kontaktovať" variant="outline" />
    </div>

    <div class="grid gap-4 lg:grid-cols-5">
      {
        testimonials.map((testimonial) => (
          <Card className="rounded-md border bg-card" size="sm">
            <CardHeader>
              <ResponsiveImage
                src={testimonial.image}
                alt={testimonial.name}
                className="size-14 rounded-md object-cover grayscale"
                sizes="56px"
              />
              <CardDescription className="leading-6">
                "{testimonial.quote}"
              </CardDescription>
            </CardHeader>
            <CardFooter className="flex-col items-start gap-1 border-t">
              <p class="font-medium">{testimonial.name}</p>
              <p class="text-muted-foreground text-sm">
                {testimonial.relation}
              </p>
            </CardFooter>
          </Card>
        ))
      }
    </div>
  </div>
</section>
