---
import { MapPinIcon } from "lucide-react"

import ReservationButton from "@/components/reservation-button.astro"
import { bookingLinks } from "@/lib/chmonya-content"
---

<section
  class="mx-auto w-full max-w-[1440px] border-b px-5 py-16 sm:px-8 lg:px-10 lg:py-24"
>
  <div class="grid gap-10 lg:grid-cols-12 lg:gap-y-14">
    <div class="flex flex-col gap-8 lg:col-span-10">
      <h2
        class="max-w-5xl text-3xl leading-tight font-medium text-balance break-words sm:text-6xl sm:leading-none"
      >
        Pohľad do zrkadla po čerstvom strihu stojí za to. Daj nám vedieť, kedy
        to chceš zažiť.
      </h2>
      <div class="grid gap-5 sm:grid-cols-[auto_minmax(0,1fr)] sm:items-start">
        <ReservationButton variant="outline" />
        <p
          class="text-muted-foreground max-w-2xl text-base leading-7 text-pretty"
        >
          Profesionálna starostlivosť, príjemná atmosféra a výsledok, s ktorým
          odídeš spokojný. Dopraj si čas pre seba.
        </p>
      </div>
    </div>

    <a
      href={bookingLinks.contact}
      aria-label="Prejsť na kontakt"
      class="hover:bg-muted focus-visible:ring-ring/30 flex min-h-32 items-center justify-between gap-5 rounded-md border p-5 transition-colors focus-visible:ring-3 focus-visible:outline-none lg:col-span-5 lg:col-start-8 lg:p-7"
    >
      <div class="flex min-w-0 flex-col gap-1">
        <p class="text-muted-foreground text-xs font-medium" translate="no">
          CHMONYA BARBER
        </p>
        <p class="text-lg font-medium text-pretty">
          na objednávky aj na počkanie
        </p>
        <p class="text-muted-foreground text-sm">KOŠICE, LUNÁRNA PASÁŽ</p>
      </div>
      <MapPinIcon className="size-5 shrink-0" />
    </a>
  </div>
</section>
