---
import { CookieSettings } from "@/components/cookie-settings"
import ResponsiveImage from "@/components/responsive-image.astro"
import { RollingLink } from "@/components/rolling-link"
import { bookingLinks, contact, instagramImages } from "@/lib/chmonya-content"
import { Separator } from "@chmonya-barber/ui/components/separator"

const footerNavItems = [
  { label: "Úvod", href: "#uvod" },
  { label: "Služby", href: "#sluzby" },
  { label: "O nás", href: "#o-nas" },
  { label: "Kontakt", href: "#kontakt" },
]

const railItems = [
  { src: instagramImages[0], className: "h-[193px] w-[132px]" },
  { src: instagramImages[1], className: "h-[110px] w-[154px]" },
  { src: instagramImages[2], className: "h-[193px] w-[150px]" },
  { src: instagramImages[3], className: "h-[245px] w-[165px]" },
  { src: instagramImages[4], className: "h-[110px] w-[154px]" },
  { src: instagramImages[5], className: "h-[193px] w-[132px]" },
  { src: instagramImages[6], className: "h-[136px] w-[190px]" },
  { src: instagramImages[7], className: "h-[193px] w-[190px]" },
]

const marqueeItems = [...railItems, ...railItems, ...railItems, ...railItems]
const contactHref = bookingLinks.contact
const phoneDisplay = contact.phone.replace("+421 ", "0")
---

<footer
  id="kontakt"
  class="bg-background text-foreground min-h-svh scroll-mt-[90px] overflow-hidden"
>
  <div class="pt-28 pb-20 sm:pt-32 sm:pb-20">
    <a
      href={contactHref}
      aria-label="Prejsť na kontakt"
      class="focus-visible:ring-ring/30 block focus-visible:ring-3 focus-visible:outline-none"
    >
      <div
        aria-hidden="true"
        class="chmonya-marquee-track flex items-start gap-2.5"
      >
        {
          marqueeItems.map((image) => (
            <span class={`block shrink-0 overflow-hidden ${image.className}`}>
              <ResponsiveImage
                src={image.src}
                alt=""
                className="h-full w-full object-cover"
                sizes="190px"
              />
            </span>
          ))
        }
      </div>
    </a>
  </div>

  <div class="mx-auto w-full max-w-[1480px] px-5 sm:px-8 lg:px-6">
    <div
      class="grid gap-12 pb-4 text-sm leading-[17px] font-semibold md:items-start"
    >
      <div class="flex flex-col gap-12">
        <div>
          <p>Prehľad</p>
          <nav aria-label="Pätičková navigácia" class="flex flex-wrap">
            {
              footerNavItems.map((item, index) => (
                <RollingLink
                  href={item.href}
                  text={`${item.label}${index < footerNavItems.length - 1 ? ", " : ""}`}
                />
              ))
            }
          </nav>
        </div>

        <CookieSettings
          client:visible
          floating={false}
          triggerClassName="h-auto self-start border-0 bg-transparent p-0 text-sm font-semibold leading-[17px] text-muted-foreground shadow-none hover:bg-transparent hover:text-foreground"
          triggerLabel="Nastavenia cookies"
        />
      </div>
    </div>

    <Separator className="bg-border/80" />

    <a
      href={bookingLinks.phone}
      aria-label={phoneDisplay}
      class="footer-phone-link focus-visible:ring-ring/30 block w-full overflow-hidden py-8 focus-visible:ring-3 focus-visible:outline-none sm:py-10"
    >
      <svg
        class="footer-phone-svg"
        viewBox="0 0 1558 230"
        aria-hidden="true"
        focusable="false"
        style="overflow: visible;"
      >
        <text
          class="footer-phone-text"
          x="5"
          y="204"
          fill="currentColor"
          textLength="1548"
          lengthAdjust="spacingAndGlyphs"
        >
          {phoneDisplay}
        </text>
      </svg>
    </a>
  </div>
</footer>

<style>
  .footer-phone-link {
    color: var(--foreground);
  }

  .footer-phone-svg {
    display: block;
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .footer-phone-text {
    fill: currentColor;
    font-family: var(--font-sans);
    font-size: 255.9416px;
    font-weight: 600;
    font-feature-settings:
      "ss01" 1,
      "ss02" 1,
      "ss07" 1,
      "cv01" 1,
      "cv09" 1,
      "cv02" 1,
      "cv03" 1,
      "cv04" 1,
      "cv12" 1,
      "cv10" 1,
      "cv08" 1,
      "cv05" 1,
      "cv07" 1,
      "cv13" 1,
      "cv06" 1;
    font-variant-numeric: slashed-zero;
    letter-spacing: 0;
  }
</style>
