---
import { CameraIcon } from "lucide-react"

import { CookieSettings } from "@/components/cookie-settings"
import ResponsiveImage from "@/components/responsive-image.astro"
import { RollingLink } from "@/components/rolling-link"
import {
  bookingLinks,
  contact,
  instagramImages,
  socialLinks,
} from "@/lib/infinity-content"
import { buttonVariants } from "@workspace/ui/components/button"
import { Separator } from "@workspace/ui/components/separator"

const footerNavItems = [
  { label: "Úvod", href: "#uvod" },
  { label: "Služby", href: "#sluzby" },
  { label: "O nás", href: "#o-nas" },
  { label: "Kontakt", href: "#kontakt" },
]

const railItems = [
  { src: instagramImages[0], className: "h-[193px] w-[132px]" },
  { src: instagramImages[1], className: "h-[110px] w-[154px]" },
  { src: instagramImages[2], className: "h-[193px] w-[150px]" },
  { src: instagramImages[3], className: "h-[245px] w-[165px]" },
  { src: instagramImages[4], className: "h-[110px] w-[154px]" },
  { src: instagramImages[5], className: "h-[193px] w-[132px]" },
  { src: instagramImages[6], className: "h-[136px] w-[190px]" },
  { src: instagramImages[7], className: "h-[193px] w-[190px]" },
]

const marqueeItems = [...railItems, ...railItems, ...railItems, ...railItems]
const phoneDisplay = contact.phone.replace("+421 ", "0")
---

<footer
  id="kontakt"
  class="bg-background text-foreground min-h-svh scroll-mt-[90px] overflow-hidden"
>
  <div class="pt-28 pb-20 sm:pt-32 sm:pb-20">
    <div class="infinity-marquee-track flex items-start gap-2.5">
      {
        marqueeItems.map((image, index) => (
          <a
            href={bookingLinks.instagram}
            aria-label={`Infinity Barber Instagram ${index + 1}`}
            class={`block shrink-0 overflow-hidden ${image.className}`}
          >
            <ResponsiveImage
              src={image.src}
              alt="Infinity Barber Instagram"
              className="h-full w-full object-cover"
              sizes="190px"
            />
          </a>
        ))
      }
    </div>
  </div>

  <div class="mx-auto w-full max-w-[1480px] px-6 sm:px-8 lg:px-6">
    <div
      class="grid gap-12 pb-4 text-sm leading-[17px] font-semibold md:grid-cols-[1fr_auto] md:items-start"
    >
      <div class="flex flex-col gap-12">
        <div>
          <p>Prehľad</p>
          <nav aria-label="Pätičková navigácia" class="flex flex-wrap">
            {
              footerNavItems.map((item, index) => (
                <RollingLink
                  href={item.href}
                  text={`${item.label}${index < footerNavItems.length - 1 ? ", " : ""}`}
                />
              ))
            }
          </nav>
        </div>

        <CookieSettings
          client:idle={{ timeout: 1500 }}
          floating={false}
          triggerClassName="h-auto self-start border-0 bg-transparent p-0 text-sm font-semibold leading-[17px] text-muted-foreground shadow-none hover:bg-transparent hover:text-foreground"
          triggerLabel="Nastavenia cookies"
        />
      </div>

      <div class="flex flex-col gap-0.5 md:items-end">
        <p>Sociálne siete</p>
        <nav aria-label="Sociálne siete" class="flex flex-wrap md:justify-end">
          {
            socialLinks.map((link, index) => (
              <RollingLink
                href={link.href}
                rel="noreferrer"
                target="_blank"
                text={`${link.label}${index < socialLinks.length - 1 ? ", " : ""}`}
              />
            ))
          }
        </nav>
      </div>
    </div>

    <Separator className="bg-border/80" />

    <a
      href={bookingLinks.phone}
      class="focus-visible:ring-ring/30 block py-8 text-[clamp(3.3rem,14vw,12.5rem)] leading-[0.9] font-semibold tracking-normal whitespace-nowrap focus-visible:ring-3 focus-visible:outline-none sm:py-10"
    >
      {phoneDisplay}
    </a>
  </div>

  <a
    href={bookingLinks.instagram}
    aria-label="Instagram"
    class={`${buttonVariants({
      size: "icon",
      variant: "secondary",
    })} fixed right-5 bottom-1/2 z-30 rounded-full shadow-xl`}
    data-slot="button"
    data-size="icon"
    data-variant="secondary"
    rel="noreferrer"
    target="_blank"
  >
    <CameraIcon />
  </a>
</footer>
