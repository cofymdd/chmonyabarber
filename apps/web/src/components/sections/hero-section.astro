---
import { Badge } from "@workspace/ui/components/badge"

import ReservationButton from "@/components/reservation-button.astro"
import ResponsiveImage from "@/components/responsive-image.astro"
import { assets, contact, heroTags } from "@/lib/infinity-content"
---

<section
  id="uvod"
  class="mx-auto flex min-h-[calc(92svh-73px)] w-full max-w-[1440px] scroll-mt-24 flex-col border-b px-5 sm:px-8 lg:px-10"
>
  <div
    class="grid flex-1 gap-8 py-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:gap-12 lg:py-10"
  >
    <div class="flex min-w-0 flex-col gap-8">
      <div class="flex flex-wrap gap-2">
        {
          heroTags.map((tag) => (
            <Badge variant="outline" className="rounded-md">
              {tag}
            </Badge>
          ))
        }
      </div>

      <div class="flex max-w-4xl flex-col gap-5">
        <p class="text-muted-foreground text-sm font-medium uppercase">
          Prešov / Eperia / 1. poschodie
        </p>
        <h1
          class="max-w-[20rem] text-5xl leading-none font-medium text-balance break-words sm:max-w-4xl sm:text-7xl lg:text-8xl"
          translate="no"
        >
          INFINITY BARBER
        </h1>
        <p
          class="text-muted-foreground max-w-2xl text-lg leading-8 text-pretty"
        >
          Strih, aký ti sadne. Starostlivosť, ktorú si zaslúžiš.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-[auto_minmax(0,1fr)] sm:items-center">
        <ReservationButton />
        <p
          class="text-muted-foreground max-w-[22rem] text-base leading-7 break-words sm:max-w-xl"
        >
          V našom barbershope sa postaráme o to, aby tvoj účes aj brada vyzerali
          presne podľa tvojich predstáv.
        </p>
      </div>
    </div>

    <div class="relative min-w-0">
      <div
        class="bg-background absolute -top-4 right-4 hidden rounded-md border px-4 py-3 text-sm lg:block"
      >
        <p class="font-medium">{contact.location}</p>
        <p class="text-muted-foreground">{contact.hours}</p>
      </div>
      <ResponsiveImage
        src={assets.hero}
        alt="Detail čerstvého pánskeho strihu v Infinity Barber"
        ratio={1}
        className="h-full w-full rounded-md object-cover grayscale"
        loading="eager"
        fetchpriority="high"
        sizes="(min-width: 1024px) 44vw, calc(100vw - 2.5rem)"
      />
    </div>
  </div>

  <div class="bg-foreground text-background grid border-t sm:grid-cols-4">
    {
      heroTags.map((tag) => (
        <div class="border-background/20 px-5 py-3 text-center text-sm font-semibold sm:border-r sm:last:border-r-0">
          {tag}
        </div>
      ))
    }
  </div>

  <div class="pointer-events-none overflow-hidden py-5 sm:py-6">
    <p
      class="text-foreground text-6xl leading-none font-black sm:text-8xl lg:text-[11rem] xl:text-[14rem]"
      translate="no"
    >
      INFINITY
    </p>
  </div>
</section>
