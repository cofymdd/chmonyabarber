---
import { DesktopNav } from "@/components/desktop-nav"
import { MobileMenu } from "@/components/mobile-menu"

type NavItem = {
  href: string
  label: string
}

interface Props {
  hours: string
  location: string
  logo: string
  navItems: NavItem[]
  phone: string
}

const { hours, location, navItems, phone } = Astro.props
---

<header
  id="site-header"
  class="bg-background fixed inset-x-0 top-0 isolate z-40"
>
  <div
    class="border-border/80 mx-auto grid h-[90px] w-full max-w-[1480px] grid-cols-[1fr_auto_1fr] items-center border-b px-6 sm:px-8 lg:px-6"
  >
    <a
      href="#uvod"
      aria-label="CHMONYA BARBER - úvod"
      class="focus-visible:ring-ring/30 flex min-w-0 flex-col items-center justify-self-start rounded-sm leading-none focus-visible:ring-3 focus-visible:outline-none"
      translate="no"
    >
      <span class="text-xl font-black tracking-[-0.06em]">CHMONYA</span>
      <span class="text-[0.58rem] font-semibold tracking-[0.18em]">BARBER</span>
    </a>

    <div class="hidden min-w-0 flex-col gap-0.5 justify-self-center md:flex">
      <p class="text-sm leading-[17px] font-semibold">Prehľad</p>
      <DesktopNav navItems={navItems} />
    </div>

    <div
      class="hidden min-w-0 flex-col gap-0.5 justify-self-end text-left text-sm leading-[17px] font-semibold lg:flex"
    >
      <a
        href="#kontakt"
        class="focus-visible:ring-ring/30 rounded-sm focus-visible:ring-3 focus-visible:outline-none"
      >
        {location}
      </a>
      <p class="text-muted-foreground">{hours}</p>
    </div>

    <div class="col-start-3 flex items-center gap-2 justify-self-end md:hidden">
      <MobileMenu
        client:media="(max-width: 767px)"
        navItems={navItems}
        location={location}
        hours={hours}
        phone={phone}
      />
    </div>
  </div>
</header>
