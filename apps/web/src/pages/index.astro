---
import { ArrowUpRightIcon, CameraIcon, MapPinIcon, PhoneIcon } from "lucide-react"

import { CookieSettings } from "@/components/cookie-settings"
import { FaqAccordion } from "@/components/faq-accordion"
import { SiteHeader } from "@/components/site-header"
import MainLayout from "@/layouts/main.astro"
import {
  assets,
  barbers,
  contact,
  faqItems,
  heroTags,
  instagramImages,
  navItems,
  priceGroups,
  siteMeta,
  socialLinks,
  styleCards,
  testimonials,
} from "@/lib/infinity-content"
import { AspectRatio } from "@workspace/ui/components/aspect-ratio"
import { Badge } from "@workspace/ui/components/badge"
import { Button } from "@workspace/ui/components/button"
import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle,
} from "@workspace/ui/components/card"
import { Separator } from "@workspace/ui/components/separator"

const phoneHref = `tel:${contact.phone.replace(/\s/g, "")}`
const mailHref = `mailto:${contact.email}`
const instagramHref = "https://www.instagram.com/infinity_barber_presov/"
---

<MainLayout title={siteMeta.title} description={siteMeta.description}>
  <SiteHeader
    client:load
    navItems={navItems}
    logo={assets.logo}
    location={contact.location}
    hours={contact.hours}
    phone={contact.phone}
  />

  <main class="overflow-hidden">
    <section
      id="uvod"
      class="mx-auto flex min-h-[calc(100svh-73px)] w-full max-w-[1440px] flex-col border-b px-5 sm:px-8 lg:px-10"
    >
      <div class="grid flex-1 gap-8 py-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:gap-12 lg:py-10">
        <div class="flex min-w-0 flex-col gap-8">
          <div class="flex flex-wrap gap-2">
            {
              heroTags.map((tag) => (
                <Badge variant="outline" className="rounded-md">
                  {tag}
                </Badge>
              ))
            }
          </div>

          <div class="flex max-w-4xl flex-col gap-5">
            <p class="text-sm font-medium uppercase text-muted-foreground">
              INFINITY BARBER / PREŠOV, EPERIA
            </p>
            <h1 class="max-w-[22rem] break-words text-4xl leading-tight font-medium sm:max-w-4xl sm:text-6xl sm:leading-none lg:text-7xl 2xl:text-8xl">
              Strih, aký ti sadne. Starostlivosť, ktorú si zaslúžiš.
            </h1>
          </div>

          <div class="grid gap-4 sm:grid-cols-[auto_1fr] sm:items-center">
            <Button asChild size="lg">
              <a href="#kontakt">
                Rezervácia
                <ArrowUpRightIcon data-icon="inline-end" />
              </a>
            </Button>
            <p class="max-w-[22rem] break-words text-base leading-7 text-muted-foreground sm:max-w-xl">
              V našom barbershope sa postaráme o to, aby tvoj účes aj brada
              vyzerali presne podľa tvojich predstáv.
            </p>
          </div>
        </div>

        <div class="relative min-w-0">
          <div class="absolute -top-4 right-4 hidden rounded-md border bg-background px-4 py-3 text-sm lg:block">
            <p class="font-medium">{contact.location}</p>
            <p class="text-muted-foreground">{contact.hours}</p>
          </div>
          <AspectRatio ratio={1}>
            <img
              src={assets.hero}
              alt="Infinity Barber haircut detail"
              class="h-full w-full rounded-md object-cover grayscale"
              loading="eager"
              fetchpriority="high"
            />
          </AspectRatio>
        </div>
      </div>

      <div class="grid border-t bg-foreground text-background sm:grid-cols-4">
        {
          heroTags.map((tag) => (
            <div class="border-background/20 px-5 py-3 text-center text-sm font-semibold sm:border-r sm:last:border-r-0">
              {tag}
            </div>
          ))
        }
      </div>

      <div class="pointer-events-none overflow-hidden py-6 sm:py-8">
        <p class="text-7xl leading-none font-black text-foreground sm:text-8xl lg:text-[12rem] xl:text-[16rem]">
          INFINITY
        </p>
      </div>
    </section>

    <section class="mx-auto grid w-full max-w-[1440px] gap-8 border-b px-5 py-16 sm:px-8 lg:grid-cols-[0.8fr_1.2fr] lg:px-10 lg:py-24">
      <a
        href={instagramHref}
        class="flex h-fit items-center justify-between gap-5 rounded-md border p-5 hover:bg-muted"
      >
        <div class="flex flex-col gap-1">
          <p class="text-xs font-medium text-muted-foreground">INFINITY BARBER</p>
          <p class="text-lg font-medium">na objednávky aj na počkanie</p>
          <p class="text-sm text-muted-foreground">PREŠOV, EPERIA</p>
        </div>
        <CameraIcon className="size-5 shrink-0" />
      </a>

      <div class="flex flex-col gap-8">
        <h2 class="max-w-4xl break-words hyphens-auto text-3xl leading-tight font-medium sm:text-6xl sm:leading-none">
          Pohľad do zrkadla po čerstvom strihu stojí za to. Daj nám vedieť,
          kedy to chceš zažiť.
        </h2>
        <div class="grid gap-5 sm:grid-cols-[auto_1fr] sm:items-start">
          <Button asChild size="lg" variant="outline">
            <a href="#kontakt">
              Rezervácia
              <ArrowUpRightIcon data-icon="inline-end" />
            </a>
          </Button>
          <p class="max-w-2xl text-base leading-7 text-muted-foreground">
            Profesionálna starostlivosť, príjemná atmosféra a výsledok, s ktorým
            odídeš spokojný. Dopraj si čas pre seba.
          </p>
        </div>
      </div>
    </section>

    <section class="mx-auto w-full max-w-[1440px] border-b px-5 py-16 sm:px-8 lg:px-10 lg:py-24">
      <div class="flex flex-col gap-8">
        <div class="flex flex-col justify-between gap-5 lg:flex-row lg:items-end">
          <div class="flex flex-col gap-3">
            <p class="text-sm font-medium uppercase text-muted-foreground">
              INFINITY BARBER / Strihy a styling
            </p>
            <h2 class="break-words hyphens-auto text-4xl leading-tight font-medium sm:text-7xl sm:leading-none">
              Trendy / Klasika /
            </h2>
          </div>
          <p class="max-w-xl text-base leading-7 text-muted-foreground">
            Malí, veľkí, mladí či starší, každý si zaslúži strih, ktorý mu
            sedí. Vďaka našim skúsenostiam vieme, ako to urobiť správne.
          </p>
        </div>

        <div class="grid gap-4 lg:grid-cols-5">
          {
            styleCards.map((style) => (
              <Card className="rounded-md border bg-card/70">
                <CardHeader>
                  <CardTitle className="flex items-start justify-between gap-4">
                    <span>{style.title}</span>
                    <span class="text-sm text-muted-foreground">({style.number})</span>
                  </CardTitle>
                  <CardDescription>{style.description}</CardDescription>
                </CardHeader>
                <CardContent className="flex flex-col gap-3">
                  <AspectRatio ratio={4 / 5}>
                    <img
                      src={style.images[0]}
                      alt={style.title}
                      class="h-full w-full rounded-md object-cover grayscale transition duration-500 hover:grayscale-0"
                      loading="lazy"
                    />
                  </AspectRatio>
                  <img
                    src={style.images[1]}
                    alt={style.description}
                    class="h-28 w-full rounded-md object-cover grayscale"
                    loading="lazy"
                  />
                </CardContent>
              </Card>
            ))
          }
        </div>
      </div>
    </section>

    <section
      id="sluzby"
      class="mx-auto grid w-full max-w-[1440px] gap-10 border-b px-5 py-16 sm:px-8 lg:grid-cols-[0.65fr_1.35fr] lg:px-10 lg:py-24"
    >
      <div class="flex flex-col gap-5">
        <p class="text-sm font-medium uppercase text-muted-foreground">
          INFINITY BARBER / Naše služby
        </p>
        <div class="flex items-end gap-4">
          <h2 class="text-6xl leading-none font-medium sm:text-8xl">Cenník</h2>
          <p class="pb-2 text-2xl text-muted-foreground">(12)</p>
        </div>
        <div class="flex flex-wrap gap-2">
          {["Umytie", "Holenie", "Styling", "Strih"].map((tag) => (
            <Badge variant="secondary" className="rounded-md">
              {tag}
            </Badge>
          ))}
        </div>
      </div>

      <div class="flex flex-col gap-8">
        {
          priceGroups.map((group) => (
            <div class="flex flex-col gap-3">
              <div class="flex items-center gap-4">
                <p class="text-sm font-semibold text-muted-foreground">
                  {group.label}
                </p>
                <Separator />
              </div>
              <div class="flex flex-col border-t">
                {group.items.map((item) => (
                  <div class="grid gap-4 border-b py-5 sm:grid-cols-[3rem_1fr_auto] sm:items-start">
                    <p class="text-sm text-muted-foreground">{item.number}</p>
                    <div class="flex min-w-0 flex-col gap-1">
                      <h3 class="text-lg font-medium">{item.name}</h3>
                      <p class="text-sm leading-6 text-muted-foreground">
                        {item.description}
                      </p>
                    </div>
                    <p class="text-xl font-semibold">{item.price}</p>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section
      id="o-nas"
      class="mx-auto grid w-full max-w-[1440px] gap-8 border-b px-5 py-16 sm:px-8 lg:grid-cols-[0.8fr_1.2fr] lg:px-10 lg:py-24"
    >
      <AspectRatio ratio={4 / 5}>
        <img
          src={assets.about}
          alt="Nožnice v barbershope"
          class="h-full w-full rounded-md object-cover grayscale"
          loading="lazy"
        />
      </AspectRatio>
      <div class="flex flex-col justify-center gap-8">
        <p class="text-sm font-medium uppercase text-muted-foreground">
          INFINITY BARBER / O nás
        </p>
          <h2 class="break-words hyphens-auto text-3xl leading-tight font-medium sm:text-6xl">
          Kreslo, uvoľnená atmosféra a náš šikovný barber. Kombinácia, vďaka
          ktorej vyzeráš dobre a cítiš sa ešte lepšie.
        </h2>
        <div class="grid gap-5 sm:grid-cols-[1fr_auto] sm:items-center">
          <p class="text-base leading-7 text-muted-foreground">
            Rezervácia ti zabezpečí pripravené kreslo, aby tvoj štýl ožil
            presne v ten správny čas.
          </p>
          <Button asChild size="lg">
            <a href="#kontakt">
              Rezervácia
              <ArrowUpRightIcon data-icon="inline-end" />
            </a>
          </Button>
        </div>
      </div>
    </section>

    <section class="mx-auto w-full max-w-[1440px] border-b px-5 py-16 sm:px-8 lg:px-10 lg:py-24">
      <div class="grid gap-8 lg:grid-cols-[0.65fr_1.35fr]">
        <div class="flex flex-col gap-6">
          <p class="text-sm font-medium uppercase text-muted-foreground">
            INFINITY BARBER / Náš tím
          </p>
          <h2 class="break-words text-5xl leading-none font-medium sm:text-8xl">
            Barberi.
          </h2>
          <img
            src={assets.team}
            alt="Infinity Barber tím"
            class="w-full rounded-md border object-cover grayscale"
            loading="lazy"
          />
          <div class="grid grid-cols-2 gap-2 text-sm text-muted-foreground">
            <span>Skúsenosti</span>
            <span>Spoľahlivosť</span>
            <span>Profesionalita</span>
            <span>Priateľskí</span>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
          {
            barbers.map((barber) => (
              <Card className="rounded-md border bg-card">
                <CardHeader>
                  <CardTitle>{barber.name}</CardTitle>
                  <CardDescription>"{barber.quote}"</CardDescription>
                </CardHeader>
                <CardFooter className="justify-between border-t text-sm text-muted-foreground">
                  <span>{barber.role}</span>
                  <span>({barber.nick})</span>
                </CardFooter>
              </Card>
            ))
          }
        </div>
      </div>
    </section>

    <section class="mx-auto w-full max-w-[1440px] border-b px-5 py-16 sm:px-8 lg:px-10 lg:py-24">
      <div class="flex flex-col gap-8">
        <div class="flex flex-col justify-between gap-5 lg:flex-row lg:items-end">
          <div class="flex flex-col gap-3">
            <p class="text-sm font-medium uppercase text-muted-foreground">
              INFINITY BARBER / Povedali ste o nás
            </p>
            <h2 class="break-words hyphens-auto text-4xl leading-tight font-medium sm:text-7xl sm:leading-none">
              Recenzie - Feedback -
            </h2>
          </div>
          <Button asChild variant="outline">
            <a href="#kontakt">
              Kontaktovať
              <ArrowUpRightIcon data-icon="inline-end" />
            </a>
          </Button>
        </div>

        <div class="grid gap-4 lg:grid-cols-5">
          {
            testimonials.map((testimonial) => (
              <Card className="rounded-md border bg-card">
                <CardHeader>
                  <img
                    src={testimonial.image}
                    alt={testimonial.name}
                    class="size-14 rounded-md object-cover grayscale"
                    loading="lazy"
                  />
                  <CardDescription className="leading-6">
                    "{testimonial.quote}"
                  </CardDescription>
                </CardHeader>
                <CardFooter className="flex-col items-start gap-1 border-t">
                  <p class="font-medium">{testimonial.name}</p>
                  <p class="text-sm text-muted-foreground">
                    {testimonial.relation}
                  </p>
                </CardFooter>
              </Card>
            ))
          }
        </div>
      </div>
    </section>

    <section class="mx-auto grid w-full max-w-[1440px] gap-8 border-b px-5 py-16 sm:px-8 lg:grid-cols-[0.75fr_1.25fr] lg:px-10 lg:py-24">
      <div class="flex flex-col gap-5">
        <p class="text-sm font-medium uppercase text-muted-foreground">
          INFINITY BARBER / Najčastejšie otázky
        </p>
        <h2 class="break-words text-5xl leading-none font-medium sm:text-7xl">
          FAQ.
        </h2>
        <AspectRatio ratio={4 / 5}>
          <img
            src={assets.faq}
            alt="Naši barberi"
            class="h-full w-full rounded-md object-cover grayscale"
            loading="lazy"
          />
        </AspectRatio>
      </div>
      <div class="flex flex-col justify-center gap-6">
        <h3 class="max-w-2xl break-words hyphens-auto text-3xl leading-tight font-medium sm:text-5xl">
          Otázky vítané, od typu nožníc až po náš kávový rituál. Pýtajte sa.
        </h3>
        <FaqAccordion client:load items={faqItems} />
      </div>
    </section>
  </main>

  <footer id="kontakt" class="bg-foreground text-background">
    <div class="mx-auto grid w-full max-w-[1440px] gap-10 px-5 py-16 sm:px-8 lg:grid-cols-[0.9fr_1.1fr] lg:px-10 lg:py-24">
      <div class="flex flex-col gap-8">
        <div class="flex flex-col gap-3">
          <p class="text-sm font-medium uppercase text-background/60">
            Kontakt / Rezervácia
          </p>
          <h2 class="text-5xl leading-none font-medium sm:text-8xl">Kontakt</h2>
        </div>
        <p class="max-w-2xl text-lg leading-8 text-background/70">
          Rezervovať termín si môžete na našom telefónnom čísle, formou správy
          na našich sociálnych sieťach alebo e-mailom.
        </p>
        <div class="flex flex-wrap gap-3">
          <Button asChild variant="secondary" size="lg">
            <a href={phoneHref}>
              <PhoneIcon data-icon="inline-start" />
              Zavolať
            </a>
          </Button>
          <Button asChild variant="outline" size="lg">
            <a href={contact.maps}>
              <MapPinIcon data-icon="inline-start" />
              Kde?
            </a>
          </Button>
        </div>
      </div>

      <div class="grid gap-5 md:grid-cols-2">
        <div class="flex flex-col gap-3 rounded-md border border-background/20 p-5">
          <p class="text-sm text-background/60">Eperia</p>
          <a href={contact.maps} class="text-2xl font-medium hover:underline">
            {contact.address}
          </a>
          <p class="text-background/70">{contact.hours}</p>
        </div>
        <div class="flex flex-col gap-3 rounded-md border border-background/20 p-5">
          <p class="text-sm text-background/60">Objednaj sa</p>
          <a href={phoneHref} class="text-2xl font-medium hover:underline">
            {contact.phone}
          </a>
          <a href={mailHref} class="break-words text-background/70 hover:underline">
            {contact.email}
          </a>
        </div>
        <div class="flex flex-col gap-3 rounded-md border border-background/20 p-5">
          <p class="text-sm text-background/60">Sociálne siete</p>
          {
            socialLinks.map((link) => (
              <a href={link.href} class="text-xl font-medium hover:underline">
                Sledujte nás na {link.label}
              </a>
            ))
          }
        </div>
        <div class="flex flex-col gap-3 rounded-md border border-background/20 p-5">
          <p class="text-sm text-background/60">Fakturačné údaje</p>
          <p class="text-xl font-medium">{contact.company}</p>
          <p class="text-background/70">{contact.billing}</p>
        </div>
      </div>
    </div>

    <div class="mx-auto flex w-full max-w-[1440px] flex-col gap-5 border-t border-background/20 px-5 py-8 sm:px-8 lg:px-10">
      <div class="flex items-center justify-between gap-5">
        <p class="text-sm font-medium text-background/60">
          INFINITY BARBER / Čo sa u nás deje
        </p>
        <a href={instagramHref} class="text-sm font-medium hover:underline">
          Instagram
        </a>
      </div>
      <div class="grid grid-cols-2 gap-2 sm:grid-cols-4 lg:grid-cols-8">
        {
          instagramImages.map((image, index) => (
            <a href={instagramHref} aria-label={`Instagram ${index + 1}`}>
              <AspectRatio ratio={1}>
                <img
                  src={image}
                  alt="Infinity Barber Instagram"
                  class="h-full w-full rounded-md object-cover grayscale transition duration-500 hover:grayscale-0"
                  loading="lazy"
                />
              </AspectRatio>
            </a>
          ))
        }
      </div>
    </div>
  </footer>

  <CookieSettings client:load />
</MainLayout>
