---
import { CookieSettings } from "@/components/cookie-settings"
import AboutSection from "@/components/sections/about-section.astro"
import BookingStrip from "@/components/sections/booking-strip.astro"
import ContactFooter from "@/components/sections/contact-footer.astro"
import FaqSection from "@/components/sections/faq-section.astro"
import HeroSection from "@/components/sections/hero-section.astro"
import PricingSection from "@/components/sections/pricing-section.astro"
import StylesSection from "@/components/sections/styles-section.astro"
import TeamSection from "@/components/sections/team-section.astro"
import TestimonialsSection from "@/components/sections/testimonials-section.astro"
import SiteHeader from "@/components/site-header.astro"
import MainLayout from "@/layouts/main.astro"
import { assets, contact, navItems, siteMeta } from "@/lib/infinity-content"
---

<MainLayout title={siteMeta.title} description={siteMeta.description}>
  <a
    href="#main-content"
    class="bg-background text-foreground ring-border fixed top-3 left-3 z-50 -translate-y-16 rounded-md px-4 py-2 text-sm font-medium shadow-xl ring-1 transition-transform focus:translate-y-0 focus:outline-none"
  >
    Preskočiť na obsah
  </a>

  <SiteHeader
    navItems={navItems}
    logo={assets.logo}
    location={contact.location}
    hours={contact.hours}
    phone={contact.phone}
  />

  <main id="main-content" class="overflow-hidden">
    <HeroSection />
    <BookingStrip />
    <StylesSection />
    <PricingSection />
    <AboutSection />
    <TeamSection />
    <TestimonialsSection />
    <FaqSection />
  </main>

  <ContactFooter />
  <CookieSettings client:idle={{ timeout: 1500 }} />
</MainLayout>
